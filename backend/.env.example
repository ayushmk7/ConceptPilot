# ============================================================================
# ConceptPilot Backend — Environment Variables
#
# Copy to `.env` and replace every YOUR_* placeholder with real values.
# Stack: Railway (API + Postgres) and Vultr Object Storage (S3-compatible).
# No Oracle Cloud (OCI).
#
# Railway: add Postgres → inject `DATABASE_URL` (often `postgresql://` — the app
# normalizes it). Release command: `alembic upgrade head`
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED — replace YOUR_* before running in production
# ----------------------------------------------------------------------------

DATABASE_URL=postgresql+asyncpg://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME

ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ----------------------------------------------------------------------------
# OPTIONAL — defaults work for local dev; set YOUR_* for production
# ----------------------------------------------------------------------------

DATABASE_SSL_MODE=prefer

CORS_ALLOWED_ORIGINS=https://YOUR_FRONTEND_URL

APP_ENV=development

# ----------------------------------------------------------------------------
# Production checklist (set before deploy)
# - APP_ENV=production
# - CORS_ALLOWED_ORIGINS set to your real frontend URL(s), never "*"
# - OBJECT_STORAGE_ENABLED=true with a reachable bucket
# - ELEVENLABS_API_KEY and ELEVENLABS_VOICE_ID (both required for audio / video_walkthrough generation)
# - DATABASE_SSL_MODE=require (or verify-full) for managed Postgres
# - COMPUTE_ASYNC_ENABLED=true requires Redis queue config below
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# ElevenLabs — required together for study content types audio and video_walkthrough
# (presentation uses Claude only). GET /health reports elevenlabs: reachable | not_configured | error.
# ----------------------------------------------------------------------------

ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
ELEVENLABS_VOICE_ID=YOUR_ELEVENLABS_VOICE_ID
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Hackathon shared student surface (optional). Empty = use seeded exam id from Alembic migration f1a2b3c4d5e6.
# Optional labels for new anonymous student workspaces (defaults are generic).
STUDENT_WORKSPACE_COURSE_NAME=Workspace
STUDENT_WORKSPACE_EXAM_NAME=Uploaded data
STUDENT_WORKSPACE_PROJECT_TITLE=Study
STUDENT_WORKSPACE_CANVAS_TITLE=Canvas

ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Optional: override model for /chat agent only (empty = same as ANTHROPIC_MODEL). Haiku reduces latency.
# ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_TIMEOUT_SECONDS=60
ANTHROPIC_MAX_RETRIES=2
ANTHROPIC_MAX_TOKENS=4096
# Optional: max output tokens for chat only (0 = use ANTHROPIC_MAX_TOKENS).
# ANTHROPIC_CHAT_MAX_TOKENS=2048

# Chat sessions without auth (replace when you have real user ids).
CHAT_DEFAULT_CREATED_BY=local

# ----------------------------------------------------------------------------
# Object Storage (S3-compatible) — uploads / export replication
#
# Vultr-prefixed vars are canonical.  You can also use the generic S3_* aliases
# below (e.g. for MinIO in local dev or Railway S3 add-ons).  If both are set,
# the Vultr-prefixed value wins.
# ----------------------------------------------------------------------------

OBJECT_STORAGE_ENABLED=false
VULTR_OBJECT_STORAGE_ENDPOINT=https://YOUR_REGION.vultrobjects.com
VULTR_OBJECT_STORAGE_ACCESS_KEY=YOUR_VULTR_ACCESS_KEY
VULTR_OBJECT_STORAGE_SECRET_KEY=YOUR_VULTR_SECRET_KEY
VULTR_OBJECT_STORAGE_BUCKET=YOUR_BUCKET_NAME

# Generic S3 aliases (used when VULTR_* equivalents are empty):
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=conceptpilot-dev

# ----------------------------------------------------------------------------
# Student tokens, uploads, rate limits
# ----------------------------------------------------------------------------

MAX_FILE_SIZE_MB=50
MAX_CSV_ROW_COUNT=500000
RATE_LIMIT_DAILY=100
RATE_LIMIT_COOLDOWN_SECONDS=2

# ----------------------------------------------------------------------------
# Exports & async compute
# ----------------------------------------------------------------------------

EXPORT_DIR=/tmp/conceptpilot_exports
COMPUTE_ASYNC_ENABLED=false
COMPUTE_QUEUE_BACKEND=file
COMPUTE_QUEUE_FILE=/tmp/conceptpilot_compute_queue.json
COMPUTE_QUEUE_REDIS_URL=redis://localhost:6379/0
COMPUTE_QUEUE_REDIS_KEY=conceptpilot:compute:queue
COMPUTE_WORKER_POLL_SECONDS=3

# ----------------------------------------------------------------------------
# Next.js frontend (local development)
# Copy these to frontend/.env.local or export in your shell.
# ----------------------------------------------------------------------------

# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# Study Content audio uses <audio src={API}/study-content/{id}/download>; the browser must reach this URL (CORS on GET for media).
#
# Local run order:
# 1. Postgres running; apply migrations: cd backend && alembic upgrade head
# 2. Backend: uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
# 3. Set APP_ENV=development and CORS_ALLOWED_ORIGINS=http://localhost:3000 (or *)
# 4. Frontend: cd frontend && npm install && npm run dev
# 5. Open http://localhost:3000
