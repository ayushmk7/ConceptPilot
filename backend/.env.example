# ConceptPilot Backend Environment Variables
# Copy this file to .env and fill in your actual values

# REQUIRED: PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/conceptpilot

# REQUIRED for AI features: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Anthropic model configuration (defaults shown)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_TIMEOUT_SECONDS=60
# ANTHROPIC_MAX_RETRIES=2
# ANTHROPIC_MAX_TOKENS=4096

# Instructor Basic Auth credentials (defaults: admin/admin)
# INSTRUCTOR_USERNAME=admin
# INSTRUCTOR_PASSWORD=admin

# Student report token expiry in days (default: 30)
# STUDENT_TOKEN_EXPIRY_DAYS=30

# Export file directory (default: /tmp/conceptpilot_exports)
# EXPORT_DIR=/tmp/conceptpilot_exports

# App environment and CORS settings
# APP_ENV=development
# CORS_ALLOWED_ORIGINS=*

# Async compute settings
# COMPUTE_ASYNC_ENABLED=false
# COMPUTE_QUEUE_BACKEND=file
# COMPUTE_QUEUE_FILE=/tmp/conceptpilot_compute_queue.json
# COMPUTE_WORKER_POLL_SECONDS=3

# OCI object storage hooks (optional, disabled by default)
# OCI_OBJECT_STORAGE_ENABLED=false
# OCI_OBJECT_STORAGE_NAMESPACE=
# OCI_BUCKET_UPLOADS=
# OCI_BUCKET_EXPORTS=
# OCI_CONFIG_FILE=~/.oci/config
# OCI_CONFIG_PROFILE=DEFAULT
